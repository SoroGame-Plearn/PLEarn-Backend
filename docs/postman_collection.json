{
  "info": {
    "name": "PLEarn Backend API",
    "description": "Progress tracking, achievement scoring, and Stellar-powered reward distribution for the PLEarn platform. See docs/API-INTEGRATION-GUIDE.md for a full walkthrough.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "challengeId", "value": "", "type": "string" },
    { "key": "resetToken", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"username\": \"jane\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewSecurePass456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stellarPublicKey\": \"GABCDEF...WALLETADDRESS\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/:id", "host": ["{{baseUrl}}"], "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Challenges",
      "item": [
        {
          "name": "List Challenges",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (Array.isArray(body) && body.length > 0) {",
                  "    pm.collectionVariables.set('challengeId', body[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/challenges", "host": ["{{baseUrl}}"], "path": ["challenges"] }
          }
        },
        {
          "name": "Get Challenge By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/challenges/{{challengeId}}", "host": ["{{baseUrl}}"], "path": ["challenges", "{{challengeId}}"] }
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Record Progress",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challengeId\": \"{{challengeId}}\",\n  \"activityType\": \"challenge_completed\",\n  \"score\": 75,\n  \"metadata\": { \"durationSeconds\": 120, \"attempts\": 1 }\n}"
            },
            "url": { "raw": "{{baseUrl}}/progress", "host": ["{{baseUrl}}"], "path": ["progress"] }
          }
        },
        {
          "name": "Get My Progress",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/progress", "host": ["{{baseUrl}}"], "path": ["progress"] }
          }
        },
        {
          "name": "Get Activity Log",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/progress/activity-log?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["progress", "activity-log"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Rewards",
      "item": [
        {
          "name": "Get My Rewards",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/rewards", "host": ["{{baseUrl}}"], "path": ["rewards"] }
          }
        }
      ]
    }
  ]
}
